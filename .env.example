# Copy this file to .env and fill in the values before starting the server.
# .env is excluded from git — never commit it.

# Required for production — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Optional — restrict CORS to your server IP (default: allow all origins)
# CORS_ORIGINS=http://192.168.1.50:8000

# Optional — override host and port (defaults: 0.0.0.0 and 8000)
# HOST=0.0.0.0
# PORT=8000
