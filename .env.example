# ============================================================
#  IT Ticketing System — Environment Configuration
#  Copy this file to .env and fill in the values.
#  .env is excluded from git — never commit secrets.
# ============================================================

# ── Required ─────────────────────────────────────────────────

# JWT signing secret. Generate a strong random key:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Never use the default in production.
SECRET_KEY=

# ── Optional ─────────────────────────────────────────────────

# Restrict CORS to your server's origin (recommended in production).
# Prevents browser-based requests from unauthorized origins.
# Default: * (allow all origins — suitable for LAN-only deployment)
# Example (single origin):
#   CORS_ORIGINS=http://192.168.1.50:8000
# Example (multiple origins, comma-separated):
#   CORS_ORIGINS=http://192.168.1.50:8000,https://helpdesk.yourdomain.com
# CORS_ORIGINS=http://192.168.1.50:8000

# Server bind host.
# Default: 0.0.0.0 (listens on all network interfaces)
# HOST=0.0.0.0

# Server port.
# Default: 8000
# PORT=8000
